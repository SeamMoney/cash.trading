generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BotInstance {
  id                 String         @id @default(cuid())
  userWalletAddress  String
  userSubaccount     String
  capitalUSDC        Float
  volumeTargetUSDC   Float
  bias               String
  strategy           String         @default("twap")
  market             String
  marketName         String
  isRunning          Boolean        @default(true)
  cumulativeVolume   Float          @default(0)
  ordersPlaced       Int            @default(0)
  currentCapitalUsed Float          @default(0)
  lastOrderTime      DateTime?
  error              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  sessionId          String?
  lastTwapOrderTime  DateTime?
  // High-risk strategy position tracking (so bot doesn't interfere with manual trades)
  activePositionSize    Float?     // Size of position opened by bot (null = no bot position)
  activePositionIsLong  Boolean?   // Direction of bot's position
  activePositionEntry   Float?     // Entry price of bot's position
  activePositionTxHash  String?    // Tx hash that opened the position
  orders             OrderHistory[]

  @@unique([userWalletAddress, userSubaccount])
  @@index([userWalletAddress])
}

model OrderHistory {
  id              String      @id @default(cuid())
  botId           String
  timestamp       DateTime    @default(now())
  txHash          String
  direction       String
  strategy        String      @default("twap")
  size            BigInt      // Changed from Int - contract sizes can exceed 2^31
  volumeGenerated Float
  success         Boolean
  entryPrice      Float?
  exitPrice       Float?
  pnl             Float       @default(0)
  positionHeldMs  Int         @default(0)
  sessionId       String?
  market          String?     // Market name (e.g., "BTC/USD")
  leverage        Int?        // Leverage used for this trade
  userSubaccount  String?     // Subaccount address this trade was executed on
  bot             BotInstance @relation(fields: [botId], references: [id], onDelete: Cascade)
  cashReward      CashRewardTransfer?

  @@index([botId])
  @@index([sessionId])
  @@index([userSubaccount])
}

enum CashRewardStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  SKIPPED
}

model CashRewardTransfer {
  id                       String           @id @default(cuid())
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  sentAt                   DateTime?
  sourceType               String
  sourceId                 String
  orderHistoryId           String?          @unique
  userWalletAddress        String
  userSubaccount           String?
  recipientAddress         String
  amountCash               Float
  amountAtomic             BigInt
  volumeGenerated          Float?
  rewardRateCashPerUsd     Float?
  status                   CashRewardStatus @default(PENDING)
  txHash                   String?
  error                    String?
  attemptCount             Int              @default(0)
  metadata                 Json?
  orderHistory             OrderHistory?    @relation(fields: [orderHistoryId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceId])
  @@index([recipientAddress])
  @@index([userWalletAddress])
  @@index([status])
  @@index([createdAt])
}

model StrategyVault {
  id                String                    @id @default(cuid())
  indicatorAddr     String
  ownerWallet       String
  decibelSubaccount String?
  vaultAddr         String?
  marketName        String
  allocationPct     Float
  status            String                    @default("ACTIVE")
  latestDecisionId  String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  decisions         IndicatorSignalDecision[]
  executions        ExecutionAudit[]

  @@unique([indicatorAddr, ownerWallet])
  @@index([indicatorAddr])
  @@index([ownerWallet])
  @@index([status])
}

model IndicatorSignalDecision {
  id              String           @id @default(cuid())
  strategyVaultId String
  indicatorAddr   String
  signal          Int
  prevSignal      Int?
  price           Float
  priceTimestamp  DateTime?
  onChainTxHash   String?
  observedAt      DateTime         @default(now())
  expiresAt       DateTime
  consumedAt      DateTime?
  source          String           @default("keeper")
  vault           StrategyVault    @relation(fields: [strategyVaultId], references: [id], onDelete: Cascade)
  executions      ExecutionAudit[]

  @@index([indicatorAddr, observedAt])
  @@index([strategyVaultId, observedAt])
  @@index([expiresAt])
}

model ExecutionAudit {
  id              String                   @id @default(cuid())
  strategyVaultId String
  decisionId      String?
  indicatorAddr   String
  requestedSignal Int
  onChainSignal   Int?
  allowed         Boolean
  status          String
  reason          String?
  marketName      String
  side            String?
  size            Float?
  sizeUsdt        Float?
  orderPrice      Float?
  decibelTxHash   String?
  subaccount      String?
  rawRequest      Json?
  rawResponse     Json?
  createdAt       DateTime                 @default(now())
  vault           StrategyVault            @relation(fields: [strategyVaultId], references: [id], onDelete: Cascade)
  decision        IndicatorSignalDecision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  @@index([strategyVaultId, createdAt])
  @@index([indicatorAddr, createdAt])
  @@index([decisionId])
  @@index([decibelTxHash])
}

// Verifiability record binding a deployed strategy package to the exact
// PineScript it came from (MASTER-PLAN WS3.1). Written by the deploy pipeline
// after compile, updated after publish; consumed by /api/launchpad/verify.
model StrategyArtifact {
  id                String   @id @default(cuid())
  sourceHash        String   @unique
  pineScript        String
  moveSource        String
  transpilerVersion String
  marketAddr        String
  packageAddress    String?  @unique
  publishTxHash     String?
  indicatorAddr     String?
  strategyVaultAddr String?
  equivalenceReport String?
  createdAt         DateTime @default(now())

  // packageAddress lookups are served by its unique index.
  @@index([indicatorAddr])
}

model DecibelIndexerCheckpoint {
  id                     String   @id @default(cuid())
  network                String
  source                 String
  lastTransactionVersion BigInt?
  lastEventIndex         Int?
  lastUnixMs             BigInt?
  status                 String   @default("idle")
  error                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([network, source])
  @@index([updatedAt])
}

model DecibelWatchedSubaccount {
  id          String   @id @default(cuid())
  network     String
  subaccount  String
  ownerWallet String?
  source      String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([network, subaccount, source])
  @@index([network, enabled])
  @@index([ownerWallet])
}

model DecibelMarket {
  id            String   @id @default(cuid())
  network       String
  marketAddress String
  marketName    String
  tickSize      Float?
  lotSize       Float?
  maxLeverage   Float?
  sizeDecimals  Int?
  priceDecimals Int?
  mode          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([network, marketAddress])
  @@index([network, marketName])
}

model DecibelMarketPrice {
  id              String   @id @default(cuid())
  network         String
  marketAddress   String
  marketName      String?
  markPrice       Float?
  midPrice        Float?
  oraclePrice     Float?
  fundingRateBps  Float?
  isFundingPositive Boolean?
  openInterest    Float?
  transactionUnixMs BigInt?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([network, marketAddress])
  @@index([network, updatedAt])
}

model DecibelMarketTrade {
  id                 String   @id @default(cuid())
  network            String
  eventKey           String
  marketAddress      String
  marketName         String?
  account            String?
  side               String?
  size               Float?
  price              Float?
  pnl                Float?
  funding            Float?
  fee                Float?
  orderId            String?
  tradeId            String?
  transactionVersion BigInt?
  transactionUnixMs  BigInt?
  raw                Json?
  createdAt          DateTime @default(now())

  @@unique([network, eventKey])
  @@index([network, marketAddress, transactionUnixMs])
  @@index([account])
}

model DecibelAccountOverview {
  id                 String   @id @default(cuid())
  network            String
  subaccount         String
  equity             Float?
  unrealizedPnl      Float?
  realizedPnl        Float?
  marginRatio        Float?
  maintenanceMargin  Float?
  leverage           Float?
  totalMargin        Float?
  totalNotional      Float?
  collateral         Float?
  crossWithdrawable  Float?
  volume30d          Float?
  raw                Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([network, subaccount])
  @@index([network, updatedAt])
}

model DecibelPosition {
  id                        String   @id @default(cuid())
  network                   String
  subaccount                String
  marketKey                 String
  marketAddress             String?
  marketName                String?
  isLong                    Boolean?
  size                      Float?
  leverage                  Float?
  entryPrice                Float?
  markPrice                 Float?
  value                     Float?
  estimatedPnl              Float?
  marginUsed                Float?
  unrealizedFunding         Float?
  estimatedLiquidationPrice Float?
  tpTriggerPrice            Float?
  slTriggerPrice            Float?
  transactionVersion        BigInt?
  raw                       Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([network, subaccount, marketKey])
  @@index([network, subaccount])
  @@index([marketAddress])
}

model DecibelOpenOrder {
  id                 String   @id @default(cuid())
  network            String
  subaccount         String
  marketAddress      String?
  marketName         String?
  orderId            String
  clientOrderId      String?
  side               String?
  price              Float?
  originalSize       Float?
  remainingSize      Float?
  orderType          String?
  status             String   @default("Open")
  transactionVersion BigInt?
  timestampUnixMs    BigInt?
  raw                Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([network, subaccount, orderId])
  @@index([network, subaccount])
  @@index([marketAddress])
}

model DecibelOrderEvent {
  id                 String   @id @default(cuid())
  network            String
  eventKey           String
  subaccount         String
  marketAddress      String?
  marketName         String?
  orderId            String?
  clientOrderId      String?
  side               String?
  price              Float?
  originalSize       Float?
  remainingSize      Float?
  orderType          String?
  status             String?
  transactionVersion BigInt?
  timestampUnixMs    BigInt?
  raw                Json?
  createdAt          DateTime @default(now())

  @@unique([network, eventKey])
  @@index([network, subaccount, timestampUnixMs])
  @@index([orderId])
}
